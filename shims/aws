#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(
  cd -- "$(dirname -- "$0")" && pwd
)"
PODMAN_HELPER_FILE="$SCRIPT_DIR/../lib/shims/shimmy-podman.sh"

if [ ! -f "$PODMAN_HELPER_FILE" ]; then
  printf 'ERROR: missing shim helper: %s\n' "$PODMAN_HELPER_FILE" >&2
  exit 1
fi

# shellcheck source=lib/shims/shimmy-podman.sh
. "$PODMAN_HELPER_FILE"

shimmy_podman_preflight_require "the aws shim"

# Podman-based AWS CLI wrapper
# Usage: shims/aws <aws-args>
# Example: shims/aws s3 ls
AWS_IMAGE=${AWS_IMAGE:-public.ecr.aws/aws-cli/aws-cli:2.31.21}

# Mount current working directory as /work
MOUNTS=( -v "$PWD":/work -w /work )

# Mount AWS credentials/config
if [ -d "$HOME/.aws" ]; then
  MOUNTS+=( -v "$HOME/.aws":/root/.aws:ro )
fi

# Forward common AWS env vars
ENV_VARS=( -e AWS_* )

# Pull policy
PODMAN_OPTS=()
if [ "${AWS_IMAGE_PULL:-}" = "always" ]; then
  PODMAN_OPTS+=( --pull=always )
fi

# Execute podman run
exec "$SHIMMY_PODMAN_BIN" run --rm -it "${PODMAN_OPTS[@]}" "${MOUNTS[@]}" "${ENV_VARS[@]}" "$AWS_IMAGE" "$@"
