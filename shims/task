#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SHIMMY_INSTALL_DIR="${SHIMMY_INSTALL_DIR:-$(cd -- "$SCRIPT_DIR/.." && pwd)}"
SHIMMY_IMAGES_DIR="${SHIMMY_IMAGES_DIR:-$SHIMMY_INSTALL_DIR/images}"
SHIMMY_SHIM_LIB_DIR="${SHIMMY_SHIM_LIB_DIR:-$SHIMMY_INSTALL_DIR/lib/shims}"
TASK_SHIM_HELPER="$SHIMMY_SHIM_LIB_DIR/task-shim.sh"

if [[ -f "$TASK_SHIM_HELPER" ]]; then
  # shellcheck source=lib/shims/task-shim.sh
  source "$TASK_SHIM_HELPER"
else
  printf 'ERROR: missing task shim helper: %s\n' "$TASK_SHIM_HELPER" >&2
  exit 1
fi

TASK_RUN_IMAGE="$(shimmy_task_resolve_image "$SHIMMY_IMAGES_DIR")"
PODMAN_OPTS=()
if [[ -n "${TASK_IMAGE:-}" && "${TASK_IMAGE_PULL:-}" = "always" ]]; then
  PODMAN_OPTS+=( --pull=always )
fi
shimmy_task_append_default_run_opts PODMAN_OPTS

TTY_OPTS=()
if shimmy_task_should_use_tty; then
  TTY_OPTS+=( -it )
fi

exec podman run --rm "${TTY_OPTS[@]}" "${PODMAN_OPTS[@]}" "$TASK_RUN_IMAGE" "$@"
