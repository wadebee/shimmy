#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SHIMMY_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"

if [[ -f "$SHIMMY_ROOT/runtime/lib/task-shim.sh" ]]; then
  # shellcheck source=runtime/lib/task-shim.sh
  source "$SHIMMY_ROOT/runtime/lib/task-shim.sh"
else
  printf 'ERROR: missing task shim helper: %s\n' "$SHIMMY_ROOT/runtime/lib/task-shim.sh" >&2
  exit 1
fi

TASK_RUN_IMAGE="$(shimmy_task_resolve_image "$SHIMMY_ROOT")"
PODMAN_OPTS=()
if [[ -n "${TASK_IMAGE:-}" && "${TASK_IMAGE_PULL:-}" = "always" ]]; then
  PODMAN_OPTS+=( --pull=always )
fi
shimmy_task_append_default_run_opts PODMAN_OPTS

TTY_OPTS=()
if shimmy_task_should_use_tty; then
  TTY_OPTS+=( -it )
fi

exec podman run --rm "${TTY_OPTS[@]}" "${PODMAN_OPTS[@]}" "$TASK_RUN_IMAGE" "$@"
