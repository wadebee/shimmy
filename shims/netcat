#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SHIMMY_INSTALL_DIR="${SHIMMY_INSTALL_DIR:-$(cd -- "$SCRIPT_DIR/.." && pwd)}"
SHIMMY_IMAGES_DIR="${SHIMMY_IMAGES_DIR:-$SHIMMY_INSTALL_DIR/images}"
SHIMMY_SHIM_LIB_DIR="${SHIMMY_SHIM_LIB_DIR:-$SHIMMY_INSTALL_DIR/lib/shims}"
CUSTOM_IMAGE_HELPER="$SHIMMY_SHIM_LIB_DIR/custom-image.sh"

if [[ -f "$CUSTOM_IMAGE_HELPER" ]]; then
  # shellcheck source=lib/shims/custom-image.sh
  source "$CUSTOM_IMAGE_HELPER"
else
  printf 'ERROR: missing custom image helper: %s\n' "$CUSTOM_IMAGE_HELPER" >&2
  exit 1
fi

if [[ -n "${NETCAT_IMAGE:-}" ]]; then
  NETCAT_RUN_IMAGE="$NETCAT_IMAGE"
else
  BUILD_ARGS=()
  if [[ -n "${NETCAT_BASE_IMAGE:-}" ]]; then
    BUILD_ARGS+=( --build-arg "NETCAT_BASE_IMAGE=$NETCAT_BASE_IMAGE" )
  fi

  NETCAT_RUN_IMAGE="$(
    shimmy_ensure_local_image \
      "localhost/shimmy-netcat" \
      "$SHIMMY_IMAGES_DIR/netcat" \
      "${NETCAT_IMAGE_BUILD:-auto}" \
      "${BUILD_ARGS[@]}"
  )"
fi

MOUNTS=( -v "$PWD":/work:rw -w /work )

PODMAN_OPTS=()
if [[ -n "${NETCAT_IMAGE:-}" && "${NETCAT_IMAGE_PULL:-}" = "always" ]]; then
  PODMAN_OPTS+=( --pull=always )
fi

exec podman run --rm -i "${PODMAN_OPTS[@]}" "${MOUNTS[@]}" "$NETCAT_RUN_IMAGE" "$@"
