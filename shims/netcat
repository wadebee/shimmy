#!/bin/sh
set -eu

SCRIPT_DIR=$(
  cd -- "$(dirname -- "$0")" && pwd
)
CUSTOM_IMAGE_HELPER_FILE=$SCRIPT_DIR/../lib/shims/custom-image.sh

NETCAT_IMAGES_DIR=$SCRIPT_DIR/../images/netcat
NETCAT_PULL_ARG=

if [ ! -f "$CUSTOM_IMAGE_HELPER_FILE" ]; then
  printf 'ERROR: missing shim helper: %s\n' "$CUSTOM_IMAGE_HELPER_FILE" >&2
  exit 1
fi

# shellcheck source=lib/shims/custom-image.sh
. "$CUSTOM_IMAGE_HELPER_FILE"

shimmy_podman_preflight_require "the netcat shim"

if [ -n "${NETCAT_IMAGE:-}" ]; then
  NETCAT_RUN_IMAGE=$NETCAT_IMAGE
else
  if [ -n "${NETCAT_BASE_IMAGE:-}" ]; then
    NETCAT_RUN_IMAGE=$(
      shimmy_local_image_ensure \
        "localhost/shimmy-netcat" \
        "$NETCAT_IMAGES_DIR" \
        "${NETCAT_IMAGE_BUILD:-auto}" \
        --build-arg "NETCAT_BASE_IMAGE=$NETCAT_BASE_IMAGE"
    )
  else
    NETCAT_RUN_IMAGE=$(
      shimmy_local_image_ensure \
        "localhost/shimmy-netcat" \
        "$NETCAT_IMAGES_DIR" \
        "${NETCAT_IMAGE_BUILD:-auto}"
    )
  fi
fi

if [ -n "${NETCAT_IMAGE:-}" ] && [ "${NETCAT_IMAGE_PULL:-}" = "always" ]; then
  NETCAT_PULL_ARG=--pull=always
fi

exec "$SHIMMY_PODMAN_BIN" run --rm -i \
  ${NETCAT_PULL_ARG:+"$NETCAT_PULL_ARG"} \
  -v "$PWD:/work:rw" \
  -w /work \
  "$NETCAT_RUN_IMAGE" \
  "$@"
