#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SHIMMY_INSTALL_DIR="${SHIMMY_INSTALL_DIR:-$(cd -- "$SCRIPT_DIR/.." && pwd)}"
SHIMMY_IMAGES_DIR="${SHIMMY_IMAGES_DIR:-$SHIMMY_INSTALL_DIR/images}"
SHIMMY_RUNTIME_DIR="${SHIMMY_RUNTIME_DIR:-$SHIMMY_INSTALL_DIR/runtime}"
CUSTOM_IMAGE_HELPER="$SHIMMY_RUNTIME_DIR/lib/custom-image.sh"

if [[ -f "$CUSTOM_IMAGE_HELPER" ]]; then
  # shellcheck source=runtime/lib/custom-image.sh
  source "$CUSTOM_IMAGE_HELPER"
else
  printf 'ERROR: missing custom image helper: %s\n' "$CUSTOM_IMAGE_HELPER" >&2
  exit 1
fi

if [[ -n "${TEXTUAL_IMAGE:-}" ]]; then
  TEXTUAL_RUN_IMAGE="$TEXTUAL_IMAGE"
else
  BUILD_ARGS=()
  if [[ -n "${TEXTUAL_BASE_IMAGE:-}" ]]; then
    BUILD_ARGS+=( --build-arg "TEXTUAL_BASE_IMAGE=$TEXTUAL_BASE_IMAGE" )
  fi

  TEXTUAL_RUN_IMAGE="$(
    shimmy_ensure_local_image \
      "localhost/shimmy-textual" \
      "$SHIMMY_IMAGES_DIR/textual" \
      "${TEXTUAL_IMAGE_BUILD:-auto}" \
      "${BUILD_ARGS[@]}"
  )"
fi

MOUNTS=( -v "$PWD":/work:rw -w /work )

PODMAN_OPTS=()
if [[ -n "${TEXTUAL_IMAGE:-}" && "${TEXTUAL_IMAGE_PULL:-}" = "always" ]]; then
  PODMAN_OPTS+=( --pull=always )
fi

exec podman run --rm -it "${PODMAN_OPTS[@]}" "${MOUNTS[@]}" "$TEXTUAL_RUN_IMAGE" "$@"
