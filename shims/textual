#!/bin/sh
set -eu

SCRIPT_DIR=$(
  cd -- "$(dirname -- "$0")" && pwd
)
CUSTOM_IMAGE_HELPER_FILE=$SCRIPT_DIR/../lib/shims/custom-image.sh

TEXTUAL_IMAGES_DIR=$SCRIPT_DIR/../images/textual
TEXTUAL_PULL_ARG=
TEXTUAL_TTY_ARG=

if [ ! -f "$CUSTOM_IMAGE_HELPER_FILE" ]; then
  printf 'ERROR: missing shim helper: %s\n' "$CUSTOM_IMAGE_HELPER_FILE" >&2
  exit 1
fi

# shellcheck source=lib/shims/custom-image.sh
. "$CUSTOM_IMAGE_HELPER_FILE"

shimmy_podman_preflight_require "the textual shim"

if [ -n "${TEXTUAL_IMAGE:-}" ]; then
  TEXTUAL_RUN_IMAGE=$TEXTUAL_IMAGE
else
  if [ -n "${TEXTUAL_BASE_IMAGE:-}" ]; then
    TEXTUAL_RUN_IMAGE=$(
      shimmy_local_image_ensure \
        "localhost/shimmy-textual" \
        "$TEXTUAL_IMAGES_DIR" \
        "${TEXTUAL_IMAGE_BUILD:-auto}" \
        --build-arg "TEXTUAL_BASE_IMAGE=$TEXTUAL_BASE_IMAGE"
    )
  else
    TEXTUAL_RUN_IMAGE=$(
      shimmy_local_image_ensure \
        "localhost/shimmy-textual" \
        "$TEXTUAL_IMAGES_DIR" \
        "${TEXTUAL_IMAGE_BUILD:-auto}"
    )
  fi
fi

if [ -n "${TEXTUAL_IMAGE:-}" ] && [ "${TEXTUAL_IMAGE_PULL:-}" = "always" ]; then
  TEXTUAL_PULL_ARG=--pull=always
fi

if [ -t 0 ] && [ -t 1 ]; then
  TEXTUAL_TTY_ARG=-it
fi

exec "$SHIMMY_PODMAN_BIN" run --rm \
  ${TEXTUAL_TTY_ARG:+"$TEXTUAL_TTY_ARG"} \
  ${TEXTUAL_PULL_ARG:+"$TEXTUAL_PULL_ARG"} \
  -v "$PWD:/work:rw" \
  -w /work \
  "$TEXTUAL_RUN_IMAGE" \
  "$@"
