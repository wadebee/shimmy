#!/bin/sh
set -eu

SCRIPT_DIR=$(
  cd -- "$(dirname -- "$0")" && pwd
)
PODMAN_HELPER_FILE=$SCRIPT_DIR/../lib/shims/shimmy-podman.sh

JQ_IMAGE=${JQ_IMAGE:-docker.io/stedolan/jq:latest}
JQ_IMAGE_PULL=${JQ_IMAGE_PULL:-}

if [ ! -f "$PODMAN_HELPER_FILE" ]; then
  printf 'ERROR: missing shim helper: %s\n' "$PODMAN_HELPER_FILE" >&2
  exit 1
fi

# shellcheck source=lib/shims/shimmy-podman.sh
. "$PODMAN_HELPER_FILE"

shimmy_podman_preflight_require "the jq shim"

if [ "$JQ_IMAGE_PULL" = "always" ]; then
  exec "$SHIMMY_PODMAN_BIN" run --rm -i --pull=always -v "$PWD:/work" -w /work "$JQ_IMAGE" "$@"
fi

exec "$SHIMMY_PODMAN_BIN" run --rm -i -v "$PWD:/work" -w /work "$JQ_IMAGE" "$@"
