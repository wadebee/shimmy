#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
if [[ -d "$SCRIPT_DIR" ]]; then
  # shellcheck source=runtime/lib/custom-image.sh
  source "$SCRIPT_DIR/lib/custom-image.sh"
fi

if [[ -n "${TESSL_IMAGE:-}" ]]; then
  TESSL_RUN_IMAGE="$TESSL_IMAGE"
else
  # Mount current working directory as /work
  MOUNTS=( -v "$PWD":/work )

  BUILD_ARGS=()
  if [[ -n "${TESSL_BASE_IMAGE:-}" ]]; then
    BUILD_ARGS+=( --build-arg "TESSL_BASE_IMAGE=$TESSL_BASE_IMAGE" )
  fi

  TESSL_RUN_IMAGE="$(
    shimmy_ensure_local_image \
      "localhost/shimmy-tessl" \
      "$SHIMMY_RUNTIME_DIR/images/tessl" \
      "${TESSL_IMAGE_BUILD:-auto}" \
      "${BUILD_ARGS[@]}"
  )"
fi

MOUNTS=( -v "$PWD":/work:rw )

if [ -d "$HOME/.tessl" ]; then
  MOUNTS+=( -v "$HOME/.tessl":/root/.tessl )
fi

ENV_VARS=( -e TESSL_* )

PODMAN_OPTS=()
if [[ -n "${TESSL_IMAGE:-}" && "${TESSL_IMAGE_PULL:-}" = "always" ]]; then
  PODMAN_OPTS+=( --pull=always )
fi

exec podman run --rm -it -m "300M" --memory-swap "1G" "${PODMAN_OPTS[@]}" "${MOUNTS[@]}" "${ENV_VARS[@]}" "$TESSL_RUN_IMAGE" "$@"
