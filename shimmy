#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$SCRIPT_DIR"

# shellcheck source=lib/repo/shimmy-env.sh
source "$ROOT_DIR/lib/repo/shimmy-env.sh"

usage() {
  cat <<'EOF'
Manage a local shimmy checkout through a single repo-root command.

Usage:
  shimmy <command> [options]

Commands:
  install [args...]     Run scripts/install-shimmy.sh
  uninstall [args...]   Run scripts/install-shimmy.sh --uninstall
  status [args...]      Run scripts/status-shimmy.sh
  update [args...]      Run scripts/update-shimmy.sh
  test [args...]        Run scripts/test-shimmy.sh
  shellenv              Print shell code to activate the installed shim paths now
  help                  Show this help

Examples:
  ./shimmy install
  ./shimmy uninstall
  ./shimmy status
  ./shimmy update --pull --build
  ./shimmy test
  eval "$(./shimmy shellenv)"
  source <(./shimmy shellenv)
EOF
}

fail() {
  printf 'ERROR: %s\n' "$*" >&2
  exit 1
}

print_shellenv() {
  local requested_install_dir="${1:-}"

  shimmy::init_home_vars "$HOME"
  shimmy::discover_install_paths "$requested_install_dir"

  if [[ ! -f "$INSTALL_MANIFEST_FILE" ]]; then
    fail "no shimmy install manifest found at $INSTALL_MANIFEST_FILE; run ./shimmy install first"
  fi

  shimmy::render_path_block \
    "$SHIMMY_SHIM_DIR" \
    "$SHIMMY_INSTALL_DIR" \
    "$SHIMMY_IMAGES_DIR" \
    "$SHIMMY_SHIM_LIB_DIR"
}

main() {
  local command="${1:-help}"

  case "$command" in
    help|-h|--help)
      usage
      ;;
    install)
      shift
      exec bash "$ROOT_DIR/scripts/install-shimmy.sh" "$@"
      ;;
    uninstall)
      shift
      exec bash "$ROOT_DIR/scripts/install-shimmy.sh" --uninstall "$@"
      ;;
    status)
      shift
      exec bash "$ROOT_DIR/scripts/status-shimmy.sh" "$@"
      ;;
    update)
      shift
      exec bash "$ROOT_DIR/scripts/update-shimmy.sh" "$@"
      ;;
    test)
      shift
      exec bash "$ROOT_DIR/scripts/test-shimmy.sh" "$@"
      ;;
    shellenv)
      shift
      if [[ $# -gt 0 ]]; then
        fail "shellenv does not accept arguments"
      fi
      print_shellenv
      ;;
    *)
      fail "unknown command: $command"
      ;;
  esac
}

main "$@"
