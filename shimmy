#!/bin/sh
set -eu

SCRIPT_DIR=$(
  cd -- "$(dirname -- "$0")" && pwd
)
ROOT_DIR=$SCRIPT_DIR

usage() {
  cat <<'EOF'
Manage shimmy from a single repo-root launcher.

Usage:
  shimmy <command> [options]

Commands:
  install [args...]     Run scripts/install-shimmy.sh
  uninstall [args...]   Run scripts/install-shimmy.sh --uninstall
  activate [args...]    Print shell code that activates the installed shim paths now
  status [args...]      Run scripts/status-shimmy.sh
  update [args...]      Run scripts/update-shimmy.sh
  test [args...]        Run scripts/test-shimmy.sh
  help                  Show this help (default action if no command is given)

Examples:
  ./shimmy install
  eval "$(./shimmy activate)"
  ./shimmy uninstall
  ./shimmy status
  ./shimmy update --pull --build --repair-startup
  ./shimmy test
EOF
}

fail() {
  printf 'ERROR: %s\n' "$*" >&2
  exit 1
}

run_repo_script() {
  script_path=${1:?script path is required}
  shift

  if [ ! -x "$script_path" ]; then
    fail "missing executable script: $script_path"
  fi

  exec "$script_path" "$@"
}

main() {
  command_name=${1:-help}

  case "$command_name" in
    help|-h|--help)
      usage
      ;;
    install)
      shift
      run_repo_script "$ROOT_DIR/scripts/install-shimmy.sh" "$@"
      ;;
    uninstall)
      shift
      run_repo_script "$ROOT_DIR/scripts/install-shimmy.sh" --uninstall "$@"
      ;;
    activate)
      shift
      run_repo_script "$ROOT_DIR/scripts/activate-shimmy.sh" "$@"
      ;;
    status)
      shift
      run_repo_script "$ROOT_DIR/scripts/status-shimmy.sh" "$@"
      ;;
    update)
      shift
      run_repo_script "$ROOT_DIR/scripts/update-shimmy.sh" "$@"
      ;;
    test)
      shift
      run_repo_script "$ROOT_DIR/scripts/test-shimmy.sh" "$@"
      ;;
    *)
      fail "unknown command: $command_name"
      ;;
  esac
}

main "$@"
